# Master Auth — used only to generate/revoke API keys
MASTER_PASSWORD=your_super_secret_master_password

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Meilisearch
MEILI_MASTER_KEY=your_meili_master_key
MEILI_HOST=http://meilisearch:7700

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# App
PORT=3000
NODE_ENV=production
